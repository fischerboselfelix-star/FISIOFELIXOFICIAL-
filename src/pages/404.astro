---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Página no encontrada — FisioFelix">
  <div class="min-h-screen bg-surface flex items-center justify-center px-4">
    <div class="text-center max-w-md">
      <p class="font-heading text-8xl font-extrabold text-primary/20 mb-4" aria-hidden="true">404</p>
      <h1 class="font-heading text-2xl font-bold text-brand mb-3">Página no encontrada</h1>
      <p class="text-slate-500 mb-8">
        La página que buscas no existe o ha sido movida.
      </p>
      <a
        href="/"
        class="inline-flex items-center gap-2 px-7 py-3.5 bg-primary hover:bg-primary-dark
               text-white font-semibold rounded-2xl shadow-soft hover:shadow-card
               transition-all duration-300 hover:-translate-y-0.5"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M19 12H5M12 5l-7 7 7 7"/>
        </svg>
        Volver al inicio
      </a>
    </div>
  </div>
</Layout>
