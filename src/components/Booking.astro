              <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
              <line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/>
              <line x1="3" y1="10" x2="21" y2="10"/>
            </svg>
          </div>
          <h4 class="font-heading font-bold text-xl text-brand mb-2">Reserva tu cita online</h4>
          <p class="text-slate-500 text-sm leading-relaxed mb-6 max-w-xs mx-auto">
            Elige el día y la hora que mejor te venga. El proceso tarda menos de 2 minutos.
          </p>
          <div class="grid grid-cols-3 gap-3 mb-7">
            <div class="bg-white rounded-2xl p-3 shadow-soft">
              <div class="w-7 h-7 rounded-full bg-primary text-white text-xs font-bold flex items-center justify-center mx-auto mb-1.5">1</div>
              <p class="text-xs text-slate-500">Elige día y hora</p>
            </div>
            <div class="bg-white rounded-2xl p-3 shadow-soft">
              <div class="w-7 h-7 rounded-full bg-primary text-white text-xs font-bold flex items-center justify-center mx-auto mb-1.5">2</div>
