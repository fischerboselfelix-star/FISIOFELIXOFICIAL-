      <div class="space-y-6 reveal">
        <h3 class="font-heading text-xl font-semibold text-brand flex items-center gap-2">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#0EA5E9" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
          Nuestras tarifas
        </h3>
        <div class="space-y-4">
          {pricing.map((tier) => (
            <div class={`relative p-5 rounded-2xl border-2 transition-all duration-200 ${tier.popular ? 'border-primary bg-gradient-to-br from-sky-50 to-white shadow-card' : 'border-slate-100 bg-white hover:border-sky-200 shadow-soft hover:shadow-card'}`}>
