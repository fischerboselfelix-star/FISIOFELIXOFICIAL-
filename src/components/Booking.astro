const bookingsUrl = "";
const whatsappNum = "34617627016";
const whatsappMsg = encodeURIComponent("Hola! Me gustaría reservar una cita en FisioFelix.");
const pricing = [
  { id: 'short', label: 'Sesión 30 min',           price: '25€',  desc: 'Revisión y tratamiento focalizado.',    popular: false },
  { id: 'long',  label: 'Sesión 1 hora',            price: '45€',  desc: 'Valoración completa + tratamiento.',   popular: true  },
  { id: 'bono',  label: 'Bono anual · 24 sesiones', price: '972€', desc: '2 sesiones/mes · 12 meses · 10% dto.', popular: false },
