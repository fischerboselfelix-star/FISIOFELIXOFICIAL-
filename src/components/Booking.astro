              <div class="flex items-center justify-between gap-4">
                <div class="min-w-0">
                  <p class="font-heading font-semibold text-brand text-base leading-tight">{tier.label}</p>
                  <p class="text-sm text-slate-400 mt-0.5">{tier.desc}</p>
                </div>
                <span class="font-heading font-bold text-2xl text-primary flex-shrink-0">{tier.price}</span>
              </div>
              <button type="button" data-tier={tier.id}
                class="pay-btn mt-4 w-full inline-flex items-center justify-center gap-2 py-2.5 px-4 rounded-xl text-sm font-semibold bg-primary/10 text-primary hover:bg-primary hover:text-white transition-all duration-200 disabled:opacity-50">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
                Pagar ahora
              </button>
            </div>
          ))}
        </div>
        <div class="flex items-center justify-center gap-6 pt-2">
          <div class="flex items-center gap-1.5 text-xs text-slate-400">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
            Pago seguro · Stripe
          </div>
          <div class="flex items-center gap-1.5 text-xs text-slate-400">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            SSL encriptado
          </div>
        </div>
        <div class="p-4 bg-sky-50/60 rounded-2xl border border-sky-100 text-sm text-slate-500 leading-relaxed">
          <strong class="text-brand">¿Primera vez?</strong> Puedes reservar directamente por WhatsApp o usando el calendario. El pago puede realizarse también en clínica.
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const BACKEND = (import.meta as any).env?.PUBLIC_BACKEND_URL ?? '';
  document.querySelectorAll<HTMLButtonElement>('.pay-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const tier = btn.dataset.tier!;
      const original = btn.innerHTML;
      btn.textContent = 'Redirigiendo…';
      btn.disabled = true;
      try {
        const res = await fetch(`${BACKEND}/api/checkout/session`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ tier, origin_url: window.location.origin }),
        });
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        const { url } = await res.json() as { url: string };
        window.location.href = url;
      } catch (err) {
        btn.innerHTML = original;
        btn.disabled = false;
        btn.textContent = '⚠ Error. Inténtalo de nuevo';
        setTimeout(() => { btn.innerHTML = original; }, 3000);
      }
    });
  });
</script>