---
/**
 * MAPA DE GOOGLE MAPS
 * ─────────────────────────────────────────────────────────────────
 * Para obtener tu iframe real:
 *   1. Ve a maps.google.com y busca la dirección
 *   2. Clic en "Compartir" → "Insertar un mapa"
 *   3. Copia únicamente el valor del atributo src=""
 *   4. Pégalo en la variable mapSrc aquí abajo
 * ─────────────────────────────────────────────────────────────────
 */
const mapSrc = "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3147.8!2d0.1040!3d38.8410!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x129e1b28e8c8cd05%3A0x1c4b33c5e6cc2975!2sCalle%20Avenida%20Campo%20Torres%2039%2C%2003700%20Dénia%2C%20Alicante!5e0!3m2!1ses!2ses!4v1700000000000";

const address = "Calle Avenida Campo Torres 39, Denia, Alicante, España";
const googleMapsLink = "https://maps.google.com/?q=Calle+Avenida+Campo+Torres+39,+Denia,+Alicante";

const hours = [
  { day: 'Lunes – Viernes', time: '9:00 – 20:00', open: true },
  { day: 'Sábados',         time: '9:00 – 14:00', open: true },
  { day: 'Domingos',        time: 'Cerrado',        open: false },
];

const contacts = [
  {
    label: 'Teléfono',
    value: '+34 617 62 70 16',
    href:  'tel:+34617627016',
    icon:  `<path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/>`,
  },
  {
    label: 'Email',
    value: 'fischerboselfelix@gmail.com',
    href:  'mailto:fischerboselfelix@gmail.com',
    icon:  `<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>`,
  },
];
---

<section id="ubicacion" class="py-20 md:py-28 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Encabezado -->
    <div class="text-center mb-16 reveal">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full
                  bg-sky-100 text-primary text-sm font-semibold mb-4">
        Encuéntranos
      </div>
      <h2 class="font-heading text-3xl md:text-4xl lg:text-5xl font-bold text-brand mb-4">
        Dónde estamos
      </h2>
      <p class="text-lg text-slate-500 max-w-xl mx-auto leading-relaxed">
        En el corazón de Denia, con fácil acceso y aparcamiento cercano.
      </p>
    </div>

    <div class="grid lg:grid-cols-5 gap-8 items-stretch">

      <!-- Mapa (3/5) -->
      <div class="lg:col-span-3 rounded-3xl overflow-hidden border border-sky-100
                  shadow-soft reveal" style="min-height: 400px;">
        <iframe
          src={mapSrc}
          width="100%"
          height="100%"
          style="border:0; min-height: 400px; display: block;"
          allowfullscreen
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title={`Mapa de ubicación: FisioFelix, ${address}`}
          class="w-full h-full"
        ></iframe>
      </div>

      <!-- Info (2/5) -->
      <div class="lg:col-span-2 flex flex-col gap-5 reveal">

        <!-- Dirección -->
        <div class="p-6 bg-surface rounded-3xl border border-sky-100 shadow-soft">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl bg-sky-100 flex items-center justify-center flex-shrink-0">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#0EA5E9"
                   stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
            </div>
            <div>
              <p class="font-semibold text-brand text-sm mb-1">Dirección</p>
              <p class="text-slate-500 text-sm leading-relaxed">
                Calle Avenida Campo Torres 39<br/>
                Denia, Alicante, España
              </p>
              <a
                href={googleMapsLink}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1 text-xs font-semibold text-primary
                       mt-2.5 hover:underline"
                aria-label="Abrir dirección en Google Maps"
              >
                Cómo llegar
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                     stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/>
                  <polyline points="15 3 21 3 21 9"/>
                  <line x1="10" y1="14" x2="21" y2="3"/>
                </svg>
              </a>
            </div>
          </div>
        </div>

        <!-- Horarios -->
        <div class="p-6 bg-surface rounded-3xl border border-sky-100 shadow-soft flex-1">
          <div class="flex items-center gap-3 mb-5">
            <div class="w-10 h-10 rounded-xl bg-sky-100 flex items-center justify-center flex-shrink-0">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#0EA5E9"
                   stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="12" r="10"/>
                <polyline points="12 6 12 12 16 14"/>
              </svg>
            </div>
            <p class="font-semibold text-brand text-sm">Horario de atención</p>
          </div>

          <ul class="space-y-0" aria-label="Horarios de apertura">
            {hours.map(h => (
              <li class="flex items-center justify-between py-3 border-b border-slate-100 last:border-0">
                <span class="text-sm text-slate-600">{h.day}</span>
                <span class={`text-xs font-semibold rounded-full px-3 py-1
                  ${h.open
                    ? 'bg-emerald-50 text-emerald-600'
                    : 'bg-slate-100 text-slate-400'}`}>
                  {h.time}
                </span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Teléfono / Email -->
        <div class="grid grid-cols-2 gap-4">
          {contacts.map(c => (
            <a
              href={c.href}
              class="p-4 bg-surface rounded-2xl border border-sky-100 shadow-soft
                     hover:shadow-card hover:-translate-y-0.5 transition-all duration-200 group"
              aria-label={`${c.label}: ${c.value}`}
            >
              <div class="w-8 h-8 rounded-lg bg-sky-100 flex items-center justify-center mb-2
                          group-hover:bg-primary transition-colors duration-200">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none"
                     stroke="#0EA5E9" stroke-width="2" stroke-linecap="round"
                     stroke-linejoin="round"
                     class="group-hover:stroke-white transition-colors duration-200"
                     aria-hidden="true">
                  <Fragment set:html={c.icon} />
                </svg>
              </div>
              <p class="text-xs font-semibold text-brand">{c.label}</p>
              <p class="text-xs text-slate-400 mt-0.5 truncate">{c.value}</p>
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
