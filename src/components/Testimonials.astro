---
const testimonials = [
  {
    name:  'María García',
    role:  'Paciente verificada',
    text:  'Tras mi operación de rodilla, Felix me ayudó a recuperar la movilidad completa en tiempo récord. Trato excepcional y muy profesional.',
    stars: 5,
  },
  {
    name:  'Carlos Fernández',
    role:  'Paciente verificado',
    text:  'Llevo años con él para la preparación deportiva. Es el mejor fisio que he tenido: sabe exactamente qué necesitas y cuándo.',
    stars: 5,
  },
  {
    name:  'Ana Martínez',
    role:  'Paciente verificada',
    text:  'Las sesiones de pilates clínico han eliminado mi dolor lumbar crónico. Muy recomendable, y las instalaciones son preciosas.',
    stars: 5,
  },
];
---

<section class="py-20 md:py-28 bg-secondary">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Encabezado -->
    <div class="text-center mb-16 reveal">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full
                  bg-white text-primary text-sm font-semibold mb-4 shadow-soft">
        Testimonios
      </div>
      <h2 class="font-heading text-3xl md:text-4xl lg:text-5xl font-bold text-brand mb-4">
        Lo que dicen nuestros pacientes
      </h2>
      <p class="text-lg text-slate-500 max-w-xl mx-auto leading-relaxed">
        La confianza de más de 500 pacientes nos motiva cada día.
      </p>
    </div>

    <!-- Grid de cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {testimonials.map((t, i) => (
        <article
          class="reveal bg-white rounded-3xl p-7 shadow-soft hover:shadow-hover
                 hover:-translate-y-1 transition-all duration-300"
          style={`transition-delay: ${i * 80}ms`}
        >
          <!-- Estrellas -->
          <div
            class="flex gap-1 mb-4"
            role="img"
            aria-label={`Valoración: ${t.stars} de 5 estrellas`}
          >
            {Array.from({ length: t.stars }).map(() => (
              <svg width="17" height="17" viewBox="0 0 24 24"
                   fill="#FBBF24" stroke="#F59E0B" stroke-width="0.5" aria-hidden="true">
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02
                                 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
              </svg>
            ))}
          </div>

          <!-- Comilla decorativa -->
          <div class="text-sky-200 mb-3" aria-hidden="true">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor">
              <path d="M3 21c3 0 7-1 7-8V5c0-1.25-.756-2.017-2-2H4c-1.25 0-2 .75-2
                       1.972V11c0 1.25.75 2 2 2 1 0 1 0 1 1v1c0 1-1 2-2 2s-1 .008-1
                       1.031V20c0 1 0 1 1 1z"/>
              <path d="M15 21c3 0 7-1 7-8V5c0-1.25-.757-2.017-2-2h-4c-1.25 0-2 .75-2
                       1.972V11c0 1.25.75 2 2 2h.75c0 2.25.25 4-2.75 4v3c0 1 0 1 1 1z"/>
            </svg>
          </div>

          <!-- Texto -->
          <p class="text-slate-600 text-sm leading-relaxed mb-6 italic">
            {t.text}
          </p>

          <!-- Autor -->
          <div class="flex items-center gap-3 pt-4 border-t border-slate-100">
            <div
              class="w-9 h-9 rounded-full flex items-center justify-center
                     text-white text-xs font-bold flex-shrink-0"
              style="background: linear-gradient(135deg, #0EA5E9, #0284C7);"
              aria-hidden="true"
            >
              {t.name[0]}
            </div>
            <div>
              <p class="font-semibold text-sm text-brand">{t.name}</p>
              <p class="text-xs text-slate-400">{t.role}</p>
            </div>
          </div>
        </article>
      ))}
    </div>

    <!-- CTA inferior -->
    <div class="text-center mt-12 reveal">
      <a
        href="#reservar"
        class="inline-flex items-center gap-2 px-7 py-4 bg-primary hover:bg-primary-dark
               text-white font-semibold rounded-2xl shadow-soft hover:shadow-hover
               transition-all duration-300 hover:-translate-y-0.5"
      >
        Únete a nuestros pacientes
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2.5" stroke-linecap="round"
             stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </div>
</section>
